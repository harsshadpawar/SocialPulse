<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.socialpulse.local</string>

  <!-- Login shell (-lc) so PATH includes node / npm / docker from your shell profile. -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>/Users/harsshadpawar/Developer/SocialPulse/SocialPulseApp/scripts/serve-local.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/harsshadpawar/Developer/SocialPulse/SocialPulseApp</string>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>20</integer>

  <key>StandardOutPath</key>
  <string>/Users/harsshadpawar/Library/Logs/socialpulse.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/harsshadpawar/Library/Logs/socialpulse.err.log</string>
</dict>
</plist>
