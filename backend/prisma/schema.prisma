// SocialPulse v0.1 — schema authority (decision #27, amended: schema.prisma is the source of truth;
// generated SQL migrations are the audit trail).
//
// ADR-2: no stored posting_status / adherence_status — they are DERIVED at read time
// from target_datetime / actual_datetime / grace / now. Stored columns are facts only.
// missed_acknowledged_at is a user attestation ("filed this miss"), read only by the selector.
//
// Platform→format pairing (decision #12) is enforced in the service layer, not as a DB constraint,
// to keep schema.prisma the single authority.

generator client {
  provider = "prisma-client-js"
  // Pinned to the target machine (MacBook Air M3). Also lets type generation run in
  // sandboxed CI/dev environments where Prisma's engine CDN is unreachable.
  binaryTargets = ["darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Platform {
  linkedin
  x
  youtube
  instagram
}

enum Format {
  text_post
  short_post
  short_video
  reel
  // v0.2f: editable formats per platform — type is now chosen, not fixed by platform.
  thread
  carousel
  video
  long_video
  image
}

enum Readiness {
  draft
  ready
}

model ContentIdea {
  id          String         @id @default(uuid()) @db.Uuid
  title       String
  coreMessage String         @map("core_message")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  posts       PlatformPost[]

  @@map("content_idea")
}

model PlatformPost {
  id                   String           @id @default(uuid()) @db.Uuid
  contentIdeaId        String           @map("content_idea_id") @db.Uuid
  idea                 ContentIdea      @relation(fields: [contentIdeaId], references: [id])
  events               AdherenceEvent[]
  platform             Platform    @default(linkedin)
  format               Format      @default(text_post)
  caption              String      @default("")
  targetDatetime       DateTime?   @map("target_datetime") @db.Timestamptz(6)
  readiness            Readiness   @default(draft)
  actualDatetime       DateTime?   @map("actual_datetime") @db.Timestamptz(6)
  nativePostUrl        String?     @map("native_post_url")
  graceWindowMinutes   Int         @default(30) @map("grace_window_minutes")
  missedAcknowledgedAt DateTime?   @map("missed_acknowledged_at") @db.Timestamptz(6)
  createdAt            DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([targetDatetime])
  @@index([contentIdeaId])
  @@map("platform_post")
}

// ADR-5: append-only log of USER ACTIONS only — derived detections (Due reached, grace expired)
// are read-time findings and are never logged. Substrate for Weekly Review (Phase 2). No UI in v0.2a.
enum AdherenceEventType {
  created
  target_edited
  marked_ready
  marked_posted
  actual_edited
  missed_acknowledged
}

model AdherenceEvent {
  id             String             @id @default(uuid()) @db.Uuid
  platformPostId String             @map("platform_post_id") @db.Uuid
  post           PlatformPost       @relation(fields: [platformPostId], references: [id])
  eventType      AdherenceEventType @map("event_type")
  at             DateTime           @default(now()) @db.Timestamptz(6)
  oldValue       String?            @map("old_value")
  newValue       String?            @map("new_value")

  @@index([platformPostId])
  @@map("adherence_event")
}

// Phase 2 (D-48): Weekly Review reflection — user-authored learning artifacts (blockers/repeat/stop),
// keyed by the Dubai ISO week. NOT derived status (so it's stored, unlike day_closure): the creator's
// words are the point of the review. One row per week; current week only in v0.2e.
model WeeklyReview {
  weekStartKey String   @id @map("week_start_key") // 'YYYY-MM-DD' Monday, Dubai
  blockers     String   @default("")
  repeat       String   @default("")
  stop         String   @default("")
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("weekly_review")
}

// D-32/D-33: one-row table; targets are data, not settings. NULL = no target for that period.
// v0.2d (D-43): extended into the "commitments" store — Goal Setup persists weekly publish target
// (= weeklyTarget), prepare-ahead, completion %, missed ceiling, and weekly effort capacity. Still
// one inline-edited row, no settings screen. All NULL-able: a commitment not set simply isn't judged.
model PostingTarget {
  id                  Int      @id @default(1)
  dailyTarget         Int?     @map("daily_target")
  weeklyTarget        Int?     @map("weekly_target")
  prepareAheadTarget  Int?     @map("prepare_ahead_target")
  completionTargetPct Int?     @map("completion_target_pct")
  missedCeiling       Int?     @map("missed_ceiling")
  weeklyCapacity      Int?     @map("weekly_capacity")
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("posting_target")
}
